#version 430

layout(local_size_x = 8, local_size_y = 8) in;
layout(rgba8, binding = 0) readonly uniform image2D inputImg;
layout(rgba8, binding = 1) writeonly uniform image2D outputImg;

void main() {
    ivec2 pos = ivec2(gl_GlobalInvocationID.xy);
    vec4 color = imageLoad(inputImg, pos);
    
    imageStore(outputImg, pos, vec4(1.0 - color.rgb, 1.0));
}
